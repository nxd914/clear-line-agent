{
  "processors": [
    {
      "name": "OpenClaw",
      "filename": "openclaw_logs.csv",
      "timestamp_columns": ["Timestamp"],
      "source_timezone": "UTC",
      "target_timezone": null,
      "column_map": {
        "agent_context":  "Project",
        "session_id":     "SessionID",
        "action_id":      "ActionID",
        "auth_key":       "ToolUsed",
        "model_id":       "Model",
        "amount":         "ComputeCost",
        "action_status":  "TaskStatus",
        "deployment_id":  "Deployment"
      },
      "constants": {
        "action_type": "ACTION"
      }
    },
    {
      "name": "Claude",
      "filename": "claude_audit.csv",
      "timestamp_columns": ["Created_At"],
      "source_timezone": "UTC",
      "target_timezone": null,
      "column_map": {
        "agent_context":  "App_Name",
        "session_id":     "Conversation_Root",
        "action_id":      "Message_UUID",
        "auth_key":       "Auth_Key_ID",
        "action_type":    "Turn_Type",
        "amount":         "Token_Price",
        "action_status":  "State",
        "deployment_id":  "Org_ID"
      },
      "constants": {
        "model_id": "ANTHROPIC"
      }
    },
    {
      "name": "LangChain",
      "filename": "langchain_trace.csv",
      "timestamp_columns": ["StartTime"],
      "source_timezone": null,
      "target_timezone": null,
      "column_map": {
        "agent_context":  "TracePath",
        "session_id":     "RunID",
        "action_id":      "StepID",
        "amount":         "EstimatedCost",
        "action_status":  "CompletionStatus",
        "deployment_id":  "ProjectID"
      },
      "constants": {
        "auth_key":    "LC_AUTH",
        "model_id":    "LC_TOKEN",
        "action_type": "CHAIN_STEP"
      }
    },
    {
      "name": "OpenAI",
      "filename": "openai_usage.csv",
      "timestamp_columns": ["RequestTime"],
      "source_timezone": "UTC",
      "target_timezone": null,
      "column_map": {
        "agent_context":  "AppID",
        "session_id":     "UserSID",
        "action_id":      "ReqID",
        "auth_key":       "ApiKeyLast4",
        "model_id":       "ModelName",
        "action_type":    "CallType",
        "amount":         "PriceUSD",
        "action_status":  "ResponseCode",
        "deployment_id":  "BillingCycle"
      },
      "constants": {}
    }
  ]
}
